R1:
conf t

! Hostname
hostname R1

! Internal interface
interface g0/1
 ip address 192.168.2.1 255.255.255.0
 no shutdown

! External interface
interface g0/0
 ip address 200.1.1.1 255.255.255.0
 no shutdown

! Loopback interface used as tunnel source
interface Loopback0
 ip address 1.1.1.1 255.255.255.255
 no shutdown

! Tunnel interface (GRE over IPSec)
interface Tunnel0
 ip unnumbered g0/1
 tunnel source Loopback0
 tunnel destination 2.2.2.2
 tunnel mode ipsec ipv4
 ip ospf 2 area 0

! Set OSPF router IDs before enabling OSPF
router ospf 1
 router-id 1.1.1.1
 network 200.1.1.0 0.0.0.255 area 0
 network 1.1.1.1 0.0.0.0 area 0

router ospf 2
 router-id 11.11.11.11
 network 192.168.2.0 0.0.0.255 area 0
 
 !IKEv2 proposal
crypto ikev2 proposal myProposal
encryption aes-cbc-256
integrity sha512
prf sha512
group 16

!IKEv2 policy
crypto ikev2 policy myIKEv2Policy
proposal myProposal

!IKEv2 keyring
crypto ikev2 keyring myKeyring
peer R2
address 2.2.2.2
pre-shared-key saar

!IKEv2 profile
crypto ikev2 profile myIKEv2Profile
match identity remote address 2.2.2.2
authentication local pre-share
authentication remote pre-share
keyring local myKeyring

!IPsec transform set
crypto ipsec transform-set myTSet esp-aes esp-sha-hmac

!IPSec profile
crypto ipsec profile myIPSecProfile
set transform-set myTSet
set ikev2-profile myIKEv2Profile

! Now go back to apply IPSec profile to tunnel
interface Tunnel0
 tunnel protection ipsec profile myIPSecProfile

end

