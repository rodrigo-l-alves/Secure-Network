ub1- 
ip link add link ens3 name ens3.10 type vlan id 10
ip addr add 192.168.10.1/24 dev ens3.10
ip link set ens3.10 up

docker network create -d macvlan \
  --subnet=192.168.10.0/24 \
  --gateway=192.168.10.1 \
  -o parent=ens3.10 \
  vlan10-net

docker run --rm -dit \
  --network vlan10-net \
  --name vlan10-alpine-1 \
  alpine ash

docker run --rm -dit \
  --network vlan10-net \
  --name vlan10-alpine-2 \
  alpine ash

