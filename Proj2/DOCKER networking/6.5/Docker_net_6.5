ub3-
sudo ip link add blue type vxlan id 33 group 239.1.1.3 ttl 5 dev ens3 dstport 4789
sudo ip addr add 10.0.0.103/24 dev blue
sudo ip link set blue up

# Create Docker macvlan network
sudo docker network create -d macvlan \
  --subnet=10.0.0.0/24 \
  --gateway=10.0.0.103 \
  -o parent=blue \
  bluenet

# Run containers
sudo docker run --privileged --net=bluenet --name=b5 --ip=10.0.0.5 -itd alpine /bin/sh
sudo docker run --privileged --net=bluenet --name=b6 --ip=10.0.0.6 -itd alpine /bin/sh



