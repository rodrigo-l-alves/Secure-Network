R1:
conf t

! Hostname
hostname R1

! Internal interface
interface g0/1
 ip address 192.168.2.1 255.255.255.0
 no shutdown

! External interface
interface g0/0
 ip address 200.1.1.1 255.255.255.0
 no shutdown

! Loopback interface used as tunnel source
interface Loopback0
 ip address 1.1.1.1 255.255.255.255
 no shutdown

! Tunnel interface (GRE over IPSec)
interface Tunnel0
 ip unnumbered g0/1
 tunnel source Loopback0
 tunnel destination 2.2.2.2
 tunnel mode ipsec ipv4
 ip ospf 2 area 0

! Set OSPF router IDs before enabling OSPF
router ospf 1
 router-id 1.1.1.1
 network 200.1.1.0 0.0.0.255 area 0
 network 1.1.1.1 0.0.0.0 area 0

router ospf 2
 router-id 11.11.11.11
 network 192.168.2.0 0.0.0.255 area 0

! IKE Phase 1 - ISAKMP Policy
crypto isakmp policy 10
 encr aes 256
 hash sha
 authentication pre-share
 group 5
 lifetime 86400

! Pre-shared key with peer
crypto isakmp key saar address 2.2.2.2

! IKE Phase 2 - IPSec transform set
crypto ipsec transform-set myTSet ah-sha-hmac

! Apply transform set to a profile
crypto ipsec profile myIPSecProfile
 set transform-set myTSet

! Now go back to apply IPSec profile to tunnel
interface Tunnel0
 tunnel protection ipsec profile myIPSecProfile

end


R2-

conf t
hostname R2

! Internal interface
interface g0/1
 ip address 192.168.3.2 255.255.255.0
 no shutdown

! External interface
interface g0/0
 ip address 200.2.2.2 255.255.255.0
 no shutdown

! Loopback used as tunnel source
interface Loopback0
 ip address 2.2.2.2 255.255.255.255
 no shutdown

! Tunnel interface - GRE over IPSec
interface Tunnel0
 ip unnumbered g0/1
 tunnel source Loopback0
 tunnel destination 1.1.1.1
 tunnel mode ipsec ipv4
 ip ospf 2 area 0

! OSPF process for external links (g0/0, Loopback0)
router ospf 1
 router-id 2.2.2.2
 network 200.2.2.0 0.0.0.255 area 0
 network 2.2.2.2 0.0.0.0 area 0

! OSPF process for internal + tunnel
router ospf 2
 router-id 22.22.22.22
 network 192.168.3.0 0.0.0.255 area 0

! IKE Phase 1 ISAKMP Policy
crypto isakmp policy 10
 encr aes 256
 hash sha
 authentication pre-share
 group 5
 lifetime 86400

! Pre-shared key for R1 Loopback IP
crypto isakmp key saar address 1.1.1.1

! IKE Phase 2 - IPSec transform set
crypto ipsec transform-set myTSet ah-sha-hmac

! IPSec profile using the transform set
crypto ipsec profile myIPSecProfile
 set transform-set myTSet
 
 ! Now go back to apply IPSec profile to tunnel
interface Tunnel0
 tunnel protection ipsec profile myIPSecProfile

end
