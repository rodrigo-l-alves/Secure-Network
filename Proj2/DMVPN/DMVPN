R1:
conf t
hostname R1

! Loopback used for Tunnel source and OSPF
interface Lo0
 ip address 1.1.1.1 255.255.255.255

! Connection to RA
interface g0/0
 ip address 200.1.1.1 255.255.255.0
 no shutdown

! LAN interface for PC1
interface g0/1
 ip address 192.168.1.1 255.255.255.0
 no shutdown

! Tunnel interface
interface Tunnel0
 ip address 10.10.10.1 255.255.255.0
 tunnel source Lo0
 tunnel mode gre multipoint
 ip nhrp network-id 1
 ip nhrp map 10.10.10.2 2.2.2.2
 ip nhrp map 10.10.10.3 3.3.3.3
 ip nhrp map multicast 2.2.2.2
 ip nhrp map multicast 3.3.3.3
 ip ospf network broadcast
 ip ospf 2 area 0

! OSPF for underlay (RA)
router ospf 1
 network 200.1.1.0 0.0.0.255 area 0
 network 1.1.1.1 0.0.0.0 area 0


! OSPF for overlay
router ospf 2
 router-id 1.1.1.1
 network 192.168.1.0 0.0.0.255 area 0
 network 10.10.10.0 0.0.0.255 area 0
 end
 

