R1:
conf t
hostname R1
int g0/1
ip add 192.168.2.1 255.255.255.0
ip ospf 2 area 0
no shut
int g0/0
ip add 200.1.1.1 255.255.255.0
ip ospf 1 area 0
no shut
int l0
ip add 1.1.1.1 255.255.255.255
ip ospf 1 area 0
int Tunnel0
ip unnumbered g0/1
tunnel source l0
tunnel destination 2.2.2.2
ip ospf 2 area 0

R2:
conf t
hostname R2

interface g0/1
 ip address 192.168.3.2 255.255.255.0
 ip ospf 2 area 0
 no shutdown

interface g0/0
 ip address 200.2.2.2 255.255.255.0
 ip ospf 1 area 0
 no shutdown

interface Loopback0
 ip address 2.2.2.2 255.255.255.255
 ip ospf 1 area 0

interface Tunnel0
 ip unnumbered g0/1
 tunnel source Loopback0
 tunnel destination 1.1.1.1
 ip ospf 2 area 0

