SLB1:

conf t
hostname SLB1
no cdp advertise-v2
no ip device tracking
no ip domain-lookup
ip routing
ip cef

! VLANs
vlan 34
vlan 35

! Client-facing interface with HSRP
interface GigabitEthernet0/0
 description === Client-facing routed interface ===
 no switchport
 ip address 192.168.1.11 255.255.255.0
 standby 1 ip 192.168.1.254
 standby 1 priority 110
 standby 1 preempt
 ip slb vserver VSERVER
 no shutdown

! Trunk to Backend Switch
interface GigabitEthernet0/1
 description === Trunk to Backend Switch ===
 switchport trunk encapsulation dot1q
 switchport mode trunk
 switchport trunk allowed vlan 34,35
 no shutdown

! VLAN interfaces (no HSRP!)
interface Vlan34
 ip address 192.168.34.11 255.255.255.0
 standby 34 ip 192.168.34.1
 standby 34 priority 110
 standby 34 preempt
 no shutdown

interface Vlan35
 ip address 192.168.35.11 255.255.255.0
 standby 35 ip 192.168.35.1
 standby 35 priority 110
 standby 35 preempt
 no shutdown

! SLB config
ip slb
ip slb serverfarm SERVERFARM
 real 192.168.34.4
  inservice
  weight 2
 exit
 real 192.168.35.5
  inservice
  weight 1
 exit
 predictor roundrobin
!
ip slb vserver VSERVER
 virtual 192.168.1.10 tcp www
 serverfarm SERVERFARM
 inservice
!
line con 0
 exec-timeout 0 0
 logging synchronous
 privilege level 15
 no login
end

