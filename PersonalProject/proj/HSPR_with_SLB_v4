conf t
hostname SwitchBackend
no cdp advertise-v2

! VLAN definitions
vlan 34
vlan 35

! Trunk interfaces to SLB devices
interface GigabitEthernet0/0
 description === Trunk to SLB1 ===
 switchport trunk encapsulation dot1q
 switchport mode trunk
 switchport trunk allowed vlan 34,35
 no shutdown

interface GigabitEthernet0/1
 description === Trunk to SLB2 ===
 switchport trunk encapsulation dot1q
 switchport mode trunk
 switchport trunk allowed vlan 34,35
 no shutdown

interface GigabitEthernet0/2
 description === Trunk to SLB3 ===
 switchport trunk encapsulation dot1q
 switchport mode trunk
 switchport trunk allowed vlan 34,35
 no shutdown

! Access ports to backend servers
interface GigabitEthernet0/3
 description === Access to WW1 (VLAN 34) ===
 switchport mode access
 switchport access vlan 34
 no shutdown

interface GigabitEthernet1/0
 description === Access to WW2 (VLAN 35) ===
 switchport mode access
 switchport access vlan 35
 no shutdown

! SVIs for internal ping/diagnostics
interface Vlan34
 ip address 192.168.34.10 255.255.255.0
 no shutdown

interface Vlan35
 ip address 192.168.35.10 255.255.255.0
 no shutdown

! No default gateway to keep neutrality across VLANs
! ip default-gateway 192.168.34.1   <-- OMITTED ON PURPOSE

end


